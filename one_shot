-- ====================================================
-- Журнал перехваченных Remote-вызовов
-- ====================================================
-- Храним последние 8 вызовов, чтобы можно было выбрать какой replay'ить.
-- Имя поля: { remote = ev, method = "FireServer", args = {...}, count = N, ts = tick() }
local hitJournal       = {}
local MAX_JOURNAL      = 8
-- Ключевые слова, по которым считаем что Remote относится к комбату.
-- Если ни одно не совпадает — игнорим (не засоряем журнал чатом / тиками / etc.)
local COMBAT_KEYWORDS = {
    "hit", "damage", "attack", "combat", "weapon", "swing", "strike",
    "skill", "ability", "fire", "shoot", "bullet", "blade", "slash",
}

local function _looksLikeCombat(remote)
    if not remote or not remote.Parent then return false end
    local n = remote.Name:lower()
    for _, kw in ipairs(COMBAT_KEYWORDS) do
        if n:find(kw, 1, true) then return true end
    end
    -- Также любим всё внутри *.CombatSystem.*
    local p = remote.Parent
    while p and p ~= game do
        local pn = p.Name:lower()
        if pn:find("combat", 1, true) or pn:find("hit", 1, true) then return true end
        p = p.Parent
    end
    return false
end

local function _pushJournal(entry)
    table.insert(hitJournal, 1, entry)
    if #hitJournal > MAX_JOURNAL then table.remove(hitJournal) end
end

-- ====================================================
-- __namecall spy
-- ====================================================
local spyHooked = false

local function installSpy()
    if spyHooked then return true end

    local hookmm    = rawget(getfenv(), "hookmetamethod")
    local getrawmt  = rawget(getfenv(), "getrawmetatable")
    local setreadon = rawget(getfenv(), "setreadonly")

    if hookmm then
        local ok, err = pcall(function()
            local oldNamecall
            oldNamecall = hookmm(game, "__namecall", function(self, ...)
                local method = getnamecallmethod and getnamecallmethod() or ""
                if (method == "FireServer"   or method == "fireServer"
                    or method == "InvokeServer" or method == "invokeServer")
                    and typeof(self) == "Instance"
                    and (self:IsA("RemoteEvent") or self:IsA("RemoteFunction"))
                    and _looksLikeCombat(self)
                then
                    local args = table.pack(...)
                    _pushJournal({
                        remote = self, method = method,
                        args = args, count = args.n, ts = tick(),
                    })
                end
                return oldNamecall(self, ...)
            end)
        end)
        if ok then
            spyHooked = true
            print("[OneShotTest] spy: hookmetamethod OK")
            return true
        else
            warn("[OneShotTest] hookmetamethod failed: " .. tostring(err))
        end
    end

    if getrawmt and setreadon then
        local ok, err = pcall(function()
            local mt = getrawmt(game)
            local oldNamecall = mt.__namecall
            setreadon(mt, false)
            mt.__namecall = function(self, ...)
                local method = getnamecallmethod and getnamecallmethod() or ""
                if (method == "FireServer"   or method == "fireServer"
                    or method == "InvokeServer" or method == "invokeServer")
                    and typeof(self) == "Instance"
                    and (self:IsA("RemoteEvent") or self:IsA("RemoteFunction"))
                    and _looksLikeCombat(self)
                then
                    local args = table.pack(...)
                    _pushJournal({
                        remote = self, method = method,
                        args = args, count = args.n, ts = tick(),
                    })
                end
                return oldNamecall(self, ...)
            end
            setreadon(mt, true)
        end)
        if ok then
            spyHooked = true
            print("[OneShotTest] spy: getrawmetatable OK")
            return true
        else
            warn("[OneShotTest] getrawmetatable failed: " .. tostring(err))
        end
    end

    warn("[OneShotTest] executor НЕ поддерживает хуки — spy недоступен")
    return false
end

-- ====================================================
-- Поиск ближайшего моба
-- ====================================================
local function findNearestMob()
    local char = LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local origin = hrp.Position

    local folder = workspace:FindFirstChild("NPCs")
    if not folder then
        warn("[OneShotTest] workspace.NPCs не найден")
        return nil
    end

    local best, bestDist = nil, math.huge
    for _, m in ipairs(folder:GetChildren()) do
        if m:IsA("Model") and m ~= char then
            local hum = m:FindFirstChildOfClass("Humanoid")
            local part = m:FindFirstChild("HumanoidRootPart")
                or m:FindFirstChild("Torso") or m.PrimaryPart
            if hum and hum.Health > 0 and part then
                local d = (part.Position - origin).Magnitude
                if d < bestDist then bestDist, best = d, m end
            end
        end
    end
    return best, bestDist
end

-- В args ищем первый Instance-Model с Humanoid и подменяем на target.
local function _swapTarget(args, count, target)
    if not target then return args, count end
    local copy = {}
    for i = 1, count do copy[i] = args[i] end
    for i = 1, count do
        local v = copy[i]
        if typeof(v) == "Instance" then
            if v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") then
                copy[i] = target
                return copy, count
            end
            if v:IsA("BasePart") then
                local p = v.Parent
                if p and p:IsA("Model") and p:FindFirstChildOfClass("Humanoid") then
                    -- args ждут BasePart? Подсунем HRP цели.
                    local newPart = target:FindFirstChild("HumanoidRootPart")
                        or target:FindFirstChild("Torso") or target.PrimaryPart
                    if newPart then copy[i] = newPart end
                    return copy, count
                end
            end
        end
    end
    return copy, count
end

-- Перед спамом стараемся "разогреть" сервер: одно настоящее Tool:Activate(),
-- чтобы сервер открыл окно для приёма ударов. Не во всех играх работает,
-- но не вредит.
local function _toolActivate()
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        pcall(function() tool:Activate() end)
    end
end

-- ====================================================
-- Replay: бахаем последний пойманный Remote N раз
-- ====================================================
local function spamLast(count, target)
    local entry = hitJournal[1]
    if not entry then
        warn("[OneShotTest] журнал пуст. Сначала ударь моба сам один раз!")
        return false, "empty journal"
    end
    if not entry.remote or not entry.remote.Parent then
        warn("[OneShotTest] последний Remote больше не существует")
        return false, "stale remote"
    end

    local args, n = _swapTarget(entry.args, entry.count, target)

    print(("[OneShotTest] spam %dx: %s:%s args=%d target=%s"):format(
        count, entry.remote:GetFullName(), entry.method, n,
        target and target.Name or "<none>"))

    _toolActivate()
    task.wait(0.05)

    local ok = 0
    for i = 1, count do
        local good = pcall(function()
            if entry.method == "FireServer" or entry.method == "fireServer" then
                entry.remote:FireServer(table.unpack(args, 1, n))
            else
                entry.remote:InvokeServer(table.unpack(args, 1, n))
            end
        end)
        if good then ok = ok + 1 end
        -- Маленькая пауза чтобы сервер не дропал по rate-limit
        if i % 10 == 0 then task.wait() end
    end
    print(("[OneShotTest] done: %d/%d успешно"):format(ok, count))
    return true, "ok"
end

